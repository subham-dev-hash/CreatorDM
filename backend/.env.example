# Server
PORT=3333
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/creatordm

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Instagram / Meta
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3333/api/auth/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token
META_API_VERSION=v21.0

# Cashfree
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENV=sandbox

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5170

# Logging
LOG_LEVEL=debug
